{"nodes": [{"id": "stitch_prd_screen_a", "label": "PRD Screen A \u2014 Bubbly Minimalism", "file_type": "document", "source_file": "apps/frontend/src/assets/stitch/prd-screen-a.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_bubbly_minimalism", "label": "Bubbly Minimalism Design Language", "file_type": "rationale", "source_file": "apps/frontend/src/assets/stitch/prd-screen-a.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Design direction combining playful bubbly shapes with minimal layout. Uses DynaPuff headings, Nunito body, rounded-2xl/3xl containers, hard tactile shadows, 60-30-10 color split (background-primary-accent), CSS custom properties (var(--bubbly-*)). Inspired by Blooket, Kahoot, Nintendo Switch UI."}, {"id": "concept_arcade_energy", "label": "Arcade Energy Aesthetic", "file_type": "rationale", "source_file": "apps/frontend/src/assets/stitch/prd-screen-a.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "High-octane visual style: vibrant primary colors, heavy drop shadows mimicking physical arcade buttons, bounce/tactile animations, chunky borders. Makes every interactive element feel pushable. Inspired by 90s arcade cabinets."}, {"id": "concept_podium_leaderboard", "label": "Podium-Style Leaderboard", "file_type": "concept", "source_file": "apps/frontend/src/assets/stitch/prd-screen-a.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Post-game ranking display: 3-step podium with 1st center (highest, gold), 2nd left (silver), 3rd right (bronze). Avatars on top of colored blocks with staggered rise animation. Runner-up list below."}], "edges": [{"source": "stitch_prd_screen_a", "target": "stitch_dashboard_ref", "relation": "references", "confidence": "EXTRA