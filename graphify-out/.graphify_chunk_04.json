    {
      "id": "sprints_service_layer_pattern",
      "label": "Service Layer Pattern",
      "file_type": "concept",
      "source_file": "docs/sprint.01/effort-plan.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "All routes must use services (not direct DB/Supabase calls) to centralize business logic, authorization, and transaction orchestration. Services sit between controllers and repositories."
    },
    {
      "id": "sprints_repository_pattern",
      "label": "Functional Repository Pattern",
      "file_type": "concept",
      "source_file": "docs/sprint.02/sprint-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Exported named functions, not classes. Follows the pattern established by user.repository.ts. Consistent across all entities. Repositories handle data access only — no business logic."
    },
    {
      "id": "sprints_bubbly_minimalism",
      "label": "Bubbly Minimalism Design Language",
      "file_type": "concept",
      "source_file": "docs/sprint.03/sprint-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "60-30-10 color scheme (--bubbly-background, --bubbly-primary, --bubbly-accent), rounded-2xl/3xl corners, DynaPuff headings, Nunito body, solid colors only, no blur/gradients."
    },
    {
      "id": "sprints_forge_classic_scoring",
      "label": "Forge Classic Scoring Algorithm",
      "file_type": "concept",
      "source_file": "docs/sprint.05/sprint-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Points = Correctness x Speed Factor. Server-side only, deterministic, reusable for leaderboard and analytics. Zero for incorrect answers. Clamps edge cases like negative remaining time."
    },
    {
      "id": "sprints_session_state_machine",
      "label": "Session State Machine",
      "file_type": "concept",
      "source_file": "docs/sprint.03/sprint-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "States: waiting, playing, paused, ended. Transition function enforces valid paths (waiting->playing, playing->paused, paused->playing, playing->ended) and throws InvalidStateTransitionError otherwise."
    },
    {
      "id": "sprints_zod_validation_schemas",
      "label": "Zod Validation Schemas",
      "file_type": "concept",
      "source_file": "docs/sprint.02/sprint-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Used for DTOs (quiz, session, auth, websocket messages) with conditional validation (superRefine for question options), middleware factories (validateBody, validateParams), and type inference via z.infer."
    },
    {
      "id": "sprints_socket_io_room_management",
      "label": "Socket.IO Room Management",
      "file_type": "concept",
      "source_file": "docs/sprint.03/sprint-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Rooms mapped to session PINs. Events: join-game, leave-game, player-joined, player-left. No room leakage between rooms. Disconnect handling for ungraceful teardowns."
    },
    {
      "id": "sprints_supabase_auth_integration",
      "label": "Supabase Auth Integration",
      "file_type": "concept",
      "source_file": "docs/sprint.01/sprint-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Uses publishable/secret API keys and JWT signing keys (ES256 preferred). authMiddleware verifies Bearer tokens via getClaims() with fallback to getUser(). No legacy JWT secret usage."
    },
    {
      "id": "sprints_share_code_and_pin",
      "label": "Share Code and PIN Utilities",
      "file_type": "concept",
      "source_file": "docs/sprint.02/sprint-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Share codes (8-char uppercase alphanumeric, no ambiguous chars, crypto.getRandomValues) identify quizzes for sharing. PINs (6-digit zero-padded numeric) identify sessions for live gameplay. Both have retry logic on collision."
    },
    {
      "id": "sprints_zoneless_change_detection",
      "label": "Zoneless Change Detection",
      "file_type": "concept",
      "source_file": "docs/sprint.03/sprint-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Angular's experimental zoneless mode (provideExperimentalZonelessChangeDetection). Removes zone.js dependency. Uses Signals for reactivity. Hybrid rendering: SSG for marketing/auth, SSR for public pages, CSR for game engine."
    }
  ],
