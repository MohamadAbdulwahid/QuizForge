    {
      "id": "concept_bubbly_minimalism",
      "label": "Bubbly Minimalism Design Language",
      "file_type": "rationale",
      "source_file": "apps/frontend/src/assets/stitch/prd-screen-a.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Design direction combining playful bubbly shapes with minimal layout. Uses DynaPuff headings, Nunito body, rounded-2xl/3xl containers, hard tactile shadows, 60-30-10 color split (background-primary-accent), CSS custom properties (var(--bubbly-*)). Inspired by Blooket, Kahoot, Nintendo Switch UI."
    },
    {
      "id": "concept_arcade_energy",
      "label": "Arcade Energy Aesthetic",
      "file_type": "rationale",
      "source_file": "apps/frontend/src/assets/stitch/prd-screen-a.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "High-octane visual style: vibrant primary colors, heavy drop shadows mimicking physical arcade buttons, bounce/tactile animations, chunky borders. Makes every interactive element feel pushable. Inspired by 90s arcade cabinets."
    },
    {
      "id": "concept_forge_classic",
      "label": "Forge Classic Game Mode",
      "file_type": "concept",
      "source_file": "docs/product-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "MVP game mode: host broadcasts questions via WebSocket, players submit answers within time limit, server validates correctness + timestamp, scoring = correctness × speed factor, real-time leaderboard updates. Delivered end-to-end by Sprint 6."
    },
    {
      "id": "concept_six_digit_pin",
      "label": "6-Digit PIN Game Joining",
      "file_type": "concept",
      "source_file": "docs/product-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Session joining mechanism: host creates session with unique 6-digit PIN, players enter PIN on play page to join lobby. Uniqueness validation ensures no collisions."
    },
    {
      "id": "concept_podium_leaderboard",
      "label": "Podium-Style Leaderboard",
      "file_type": "concept",
      "source_file": "apps/frontend/src/assets/stitch/prd-screen-a.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Post-game ranking display: 3-step podium with 1st center (highest, gold), 2nd left (silver), 3rd right (bronze). Avatars on top of colored blocks with staggered rise animation. Runner-up list below."
    },
    {
      "id": "concept_session_state_machine",
      "label": "Session State Machine",
      "file_type": "concept",
      "source_file": "docs/product-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Game session lifecycle: waiting → playing → paused → ended. Controls game flow transitions, host can advance questions, end session broadcasts to all players."
    },
    {
      "id": "concept_tactile_ui",
      "label": "Tactile UI Pattern",
      "file_type": "rationale",
      "source_file": "apps/frontend/src/assets/stitch/prd-screen-b.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Neo-Brutalism meets Arcade: 4px solid borders, 8px hard shadows, 16px border radius everywhere. On click, elements translate 4px down-right and shadow reduces to 4px. Creates physical pushable button feel."
    },
    {
      "id": "concept_speed_scoring",
      "label": "Speed-Based Scoring Algorithm",
      "file_type": "concept",
      "source_file": "docs/product-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Points = Correctness × Speed Factor. Server-side validation with timestamp prevents cheating. Score deltas broadcast to all players in real-time after each question."
    },
    {
      "id": "concept_treasure_forge",
      "label": "Treasure Forge Game Mode",
      "file_type": "concept",
      "source_file": "docs/product-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Post-MVP game mode: weighted random chest generation after correct answers. Chest contents include gold, multiplier, steal (10% from leader), swap (random player). Gold counter with animations."
    },
    {
      "id": "concept_bubbly_royale",
      "label": "Bubbly Royale Game Mode",
      "file_type": "concept",
      "source_file": "docs/product-backlog.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Post-MVP 1v1 duel mode: matchmaking (random or ELO), split-screen UI, life bubble elimination (3 lives), win condition = correct + faster, spectator mode for eliminated players."
    },
    {
      "id": "concept_bubbly_ui_components",
      "label": "Bubbly UI Component Library",
      "file_type": "concept",
      "source_file": "apps/frontend/src/app/features/dashboard/groups/groups-create-page.component.html",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Shared standalone Angular components: BubblyButton (tone/size/full), BubblyCard (tone/padded/interactive), BubblyInput (CVA form input), BubblySelect (CVA select), BubblyAlert (variant/dismissible), BubblyModal (visible/confirm/danger), PageHeading (eyebrow/title/description), BubblyBadge (count/tone). All use Bubbly Minimalism design tokens."
    }
  ],
