# Supabase Configuration
# Get these values from your Supabase project settings (Project > API)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key-here"

# API Configuration
VITE_API_BASE_URL="http://localhost:3333"
VITE_WEBSOCKET_URL="http://localhost:3333"

# Sentry Configuration (optional — leave unset to disable)
VITE_SENTRY_DSN="https://your-project-key@sentry.io/project-id"
