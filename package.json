  "scripts": {
    "prepare": "husky",
    "_comment:general": "==================== GENERAL ====================",
    "lint": "nx run-many -t lint",
    "lint:affected": "nx affected -t lint --uncommitted",
    "test": "nx run-many -t test",
    "test:affected": "nx affected -t test --uncommitted",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "_comment:backend": "==================== BACKEND ====================",
    "lint:backend": "nx lint backend",
    "test:backend": "nx test backend",
    "start:backend": "nx serve backend",
    "dev:backend": "nx serve backend --watch",
    "_comment:frontend": "==================== FRONTEND ====================",
    "lint:frontend": "nx lint frontend",
    "test:frontend": "nx test frontend",
    "build:frontend": "nx build frontend",
    "start:frontend": "nx serve frontend",
    "dev:frontend": "nx serve frontend --configuration=development",
    "e2e:frontend": "nx run frontend-e2e:e2e",
    "e2e:backend": "nx run backend-e2e:e2e",
    "e2e": "nx run-many -t e2e",
    "db:init": "nx run backend:db:init",
    "db:reset": "nx run backend:db:reset",
    "db:push": "nx run backend:db:push",
    "db:pull": "nx run backend:db:pull",
    "db:link": "nx run backend:db:link",
    "db:generate": "nx run backend:db:generate",
    "seed": "nx run backend:db:seed",
    "swagger:generate": "bun run generate:api-docs",
    "swagger:ui": "nx run backend:serve",
    "generate:api-docs": "cd apps/backend && bunx tspec generate --specPathGlobs src/api/quizforge-api.spec.ts --tsconfigPath tsconfig.app.json --outputPath src/assets/swagger.json --openapiTitle QuizForge Backend API --openapiVersion 1.0.0",
    "docs:api": "bun run generate:api-docs"
  }
